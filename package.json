{
  "name": "vue3-click-outside-directive",
  "version": "1.0.2",
  "description": "Vue 3 directive that fires when a click is registered outside the element",
  "type": "module",
  "main": "./dist/v-click-outside.umd.js",
  "module": "./dist/v-click-outside.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/v-click-outside.es.js",
      "require": "./dist/v-click-outside.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vue",
    "vue3",
    "directive",
    "click-outside",
    "nuxt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MarkGareev/v-click-outside"
  },
  "homepage": "https://github.com/MarkGareev/v-click-outside#readme",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5",
    "vue": "^3.5.34"
  }
}
